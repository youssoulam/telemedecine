<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Réprésentation de la vue liste -->
    <record id="telemedecine_patient_view_list" model="ir.ui.view">
        <field name="name">telemedecine.patient.view.list</field>
        <field name="model">telemedecine.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="prenom" />
                <field name="nom_famille" />
                <field name="securite_sociale" />
                <field name="mutuelle" />
            </list>
        </field>
    </record>

    <!-- Réprésentation de la vue forme -->
    <record id="telemedecine_patient_view_form" model="ir.ui.view">
        <field name="name">telemedecine.patient.view.form</field>
        <field name="model">telemedecine.patient</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="prenom"/>
                            <field name="nom_famille"/>
                            <field name="sexe"/>
                            <field name="date_naissance"/>
                        </group>
                        <group>
                            <field name="securite_sociale"/>
                            <field name="mutuelle"/>
                            <field name="telephone"/>
                            <field name="email"/>
                            <field name="ald"/>
                        </group>
                    </group>
                    <notebook>
                        <page name='allergie' string="Allergie">
                            <field name="allergie" />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Réprésentation de l'action pour faire le lien entre 
    les vues et le menu -->
    <record model="ir.actions.act_window" id="action_telemedecine_patient">
        <field name="name">Patients</field>
        <field name="res_model">telemedecine.patient</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="telemedecine_patient_view_list"/>
    </record>




</odoo>
