<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Réprésentation de la vue liste -->
    <record id="telemedecine_medecin_view_list" model="ir.ui.view">
        <field name="name">telemedecine.medecin.view.list</field>
        <field name="model">telemedecine.medecin</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="prenom" />
                <field name="nom_famille" />
                <field name="specialite" />
                <field name="secteur" />
                <field name="tarif" />
            </list>
        </field>
    </record>

    <!-- Réprésentation de la vue forme -->
    <record id="telemedecine_medecin_view_form" model="ir.ui.view">
        <field name="name">telemedecine.medecin.view.form</field>
        <field name="model">telemedecine.medecin</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="prenom"/>
                            <field name="nom_famille"/>
                            <field name="rpps"/>
                            <field name="adeli"/>
                        </group>
                        <group>
                            <field name="specialite"/>
                            <field name="secteur"/>
                            <field name="tarif"/>
                            <field name="mode_consultation"/>
                            <field name="telephone"/>
                            <field name="email" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Réprésentation de l'action pour faire le lien entre 
    les vues et le menu -->
    <record model="ir.actions.act_window" id="action_telemedecine_medecin">
        <field name="name">Médecins</field>
        <field name="res_model">telemedecine.medecin</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="telemedecine_medecin_view_list"/>
    </record>




</odoo>
